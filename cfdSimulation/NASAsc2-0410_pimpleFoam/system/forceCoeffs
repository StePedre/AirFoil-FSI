forceCoeffs1
{
    type            forceCoeffs;

    libs            (forces);

    writeControl    timeStep;
    timeInterval    1;

    log             no;

    patches         (NASAsc2-0410Group);
    rho             rhoInf;
    rhoInf          1.225;
    liftDir         (0 1 0);
    dragDir         (1 0 0);
    CofR            (0.25 0 0);
    pitchAxis       (0 0 1);
    magUInf         100;
    lRef            1.00759691;       
    Aref            3.021088075; 
}

