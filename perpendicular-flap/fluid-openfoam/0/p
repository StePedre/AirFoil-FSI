FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

pOut            1e5;

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform $pOut;

boundaryField
{
    inlet
    {
	type 		zeroGradient;
    }

    outlet
    {
        type            fixedValue;
        value		$internalField;
    }

    domainWalls
    {
        type            fixedValue;
        value           $internalField;
    }

    NASAsc2-0410Group
    {
        type            zeroGradient;
    }

    #includeEtc "caseDicts/setConstraintTypes"
}


